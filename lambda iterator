import json
import boto3
import random
import time
from datetime import datetime

# Initialize Kinesis client
kinesis_client = boto3.client('kinesis')

def generate_mock_log(log_id):
    """Generate a mock log entry with random data."""
    log_levels = ['INFO', 'WARNING', 'ERROR', 'DEBUG']
    services = ['auth-service', 'payment-service', 'user-service', 'order-service']
    messages = [
        'User login successful',
        'Payment processed',
        'Order created',
        'Database connection failed',
        'Cache miss occurred'
    ]
    
    log_entry = {
        'log_id': log_id,
        'timestamp': datetime.utcnow().isoformat(),
        'service': random.choice(services),
        'level': random.choice(log_levels),
        'message': random.choice(messages),
        'details': {
            'user_id': random.randint(1000, 9999),
            'transaction_id': f'tx-{random.randint(100000, 999999)}',
            'response_time': round(random.uniform(0.1, 2.0), 2),
            'error_code': random.choice(['404', '500', '200', '401']) if random.random() > 0.7 else None
        }
    }
    return log_entry

def lambda_handler(event, context):
    # Parameters for controlling log generation
    num_records = int(event.get('num_records', 10))  # Number of records to generate per iteration
    iterations = int(event.get('iterations', 1))   # Number of iterations (bursts of data)
    run_indefinitely = event.get('run_indefinitely', False)  # Run indefinitely if true
    stream_name = event.get('stream_name', 'my-kinesis-stream')  # Kinesis stream name
    
    # Log generation and sending to Kinesis
    iteration_count = 0
    while run_indefinitely or iteration_count < iterations:
        iteration_count += 1
        print(f"Iteration {iteration_count}")
        
        for i in range(num_records):
            log_entry = generate_mock_log(i)
            
            # Send log to Kinesis stream
            response = kinesis_client.put_record(
                StreamName=stream_name,
                Data=json.dumps(log_entry),
                PartitionKey=str(log_entry['log_id'])
            )
            
            print(f"Sent log {i} to Kinesis: {response['SequenceNumber']}")
        
        # Optional: Add a delay between iterations to simulate bursts
        if (run_indefinitely or iteration_count < iterations) and iteration_count != iterations:
            time.sleep(5)  # 5-second delay between iterations
    
    return {
        'statusCode': 200,
        'body': json.dumps(f'Successfully sent {num_records * iteration_count} logs to {stream_name}')
    }
